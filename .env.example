# LibreNotebook configuration. Copy to `.env` and edit. Anything you
# don't need can stay commented out — sensible defaults apply.

# ─── Server ────────────────────────────────────────────────────────
# Listening port (server mode). Defaults to 5173.
# PORT=5173

# Bind address. Defaults to 127.0.0.1 (localhost-only). Use 0.0.0.0 in
# Docker / when serving on a LAN.
# HOST=127.0.0.1

# Where notebooks / vectors / auth DB live. Defaults to a per-user
# platformdir (XDG_DATA_HOME/librenotebook on Linux, similar on
# mac/win). Override for Docker bind mounts.
# LIBRENOTEBOOK_DATA_DIR=/data

# ─── Logging ───────────────────────────────────────────────────────
# DEBUG | INFO | WARN | ERROR. Default INFO.
# LOG_LEVEL=INFO

# Set to 0 to disable the .data/librenotebook.log file (console only).
# LOG_FILE=1

# ─── Optional system deps ─────────────────────────────────────────
# Absolute path to yt-dlp if it isn't on $PATH.
# YT_DLP_PATH=/usr/local/bin/yt-dlp

# ─── Provider preset (operators only) ─────────────────────────────
# When BOTH `LLM_BASE_URL` and `LLM_MODEL` are set, the chat provider
# is locked server-side and the onboarding form renders read-only for
# this provider. Same for the embedding pair below.
#
# Useful for shipping a preconfigured deployment without exposing API
# keys to end users.

# LLM_PROVIDER=openai            # "openai" (covers OpenAI / vLLM / Together / OpenRouter / …) or "ollama"
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_API_KEY=sk-...
# LLM_MODEL=gpt-4o-mini
# LLM_HAS_VISION=true            # 1/true/yes — only for OpenAI-style; Ollama auto-detects
# LLM_NUM_CTX=auto               # auto | <int>  (Ollama only)

# EMBEDDING_PROVIDER=openai
# EMBEDDING_BASE_URL=https://api.openai.com/v1
# EMBEDDING_API_KEY=sk-...
# EMBEDDING_MODEL=text-embedding-3-small

# ─── Multi-user mode (server mode only) ────────────────────────────
# Enable to require sign-in. Each user gets their own notebooks,
# vectors, and chat history. Window mode (the desktop app) ignores
# this flag.
# MULTI_USER=1

# Random secret used by Better Auth to sign sessions. Generate with
#   openssl rand -hex 32
# BETTER_AUTH_SECRET=replace-me

# Public URL the auth callbacks should resolve to.
# BETTER_AUTH_URL=http://localhost:5173

# ─── SMTP (for password reset / email verification) ───────────────
# Required when MULTI_USER=1 and you want password resets. Without it,
# the auth UI hides the "forgot password" affordance.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587                  # 465 → implicit TLS, anything else → STARTTLS
# SMTP_USER=postmaster@example.com
# SMTP_PASS=
# SMTP_FROM="LibreNotebook <no-reply@example.com>"
