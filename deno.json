{
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update .",
    "neu": "MULTI_USER=0 npx -y @neutralinojs/neu run",
    "neu:build": "npx -y @neutralinojs/neu build --release",
    "neu:update": "npx -y @neutralinojs/neu update",
    "test": "deno test --allow-all --no-check tests/",
    "test:unit": "deno test --allow-all --no-check tests/unit/",
    "test:integration": "deno test --allow-all --no-check tests/integration/",
    "test:e2e": "deno test --allow-all --no-check tests/0*.test.ts",
    "server": "deno serve -A _fresh/server.js",
    "compile": "bash scripts/build.sh",
    "build:deb": "bash scripts/build-deb.sh",
    "build:appimage": "bash scripts/build-appimage.sh",
    "build:rpm": "bash scripts/build-rpm.sh",
    "build:deb:arm64": "LN_TARGET_OS=linux LN_TARGET_ARCH=aarch64 bash scripts/build-deb.sh",
    "build:rpm:arm64": "LN_TARGET_OS=linux LN_TARGET_ARCH=aarch64 bash scripts/build-rpm.sh",
    "build:appimage:arm64": "LN_TARGET_OS=linux LN_TARGET_ARCH=aarch64 bash scripts/build-appimage.sh",
    "build:macos": "LN_TARGET_OS=macos bash scripts/build-macos.sh",
    "build:macos:x64": "LN_TARGET_OS=macos LN_TARGET_ARCH=x86_64 bash scripts/build-macos.sh",
    "build:macos:arm64": "LN_TARGET_OS=macos LN_TARGET_ARCH=aarch64 bash scripts/build-macos.sh",
    "build:windows": "LN_TARGET_OS=windows LN_TARGET_ARCH=x86_64 bash scripts/build-windows.sh"
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./src/",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "@std/log": "jsr:@std/log@^0.224.14",
    "@std/fmt/colors": "jsr:@std/fmt@^1.0.10/colors",
    "@std/dotenv": "jsr:@std/dotenv@^0.225.5",
    "better-auth": "npm:better-auth@^1.3",
    "better-auth/": "npm:/better-auth@^1.3/",
    "better-sqlite3": "npm:better-sqlite3@^11",
    "nodemailer": "npm:nodemailer@^6.9",
    "preact": "npm:preact@^10.29.1",
    "@preact/signals": "npm:@preact/signals@^2.9.0",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "vite": "npm:vite@^7.1.3",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.1.12",
    "source-map-js": "npm:source-map-js@^1.2.1",
    "langchain": "npm:langchain@^1.3.5",
    "langchain/": "npm:/langchain@^1.3.5/",
    "@langchain/core": "npm:@langchain/core@^1.1.44",
    "@langchain/core/": "npm:/@langchain/core@^1.1.44/",
    "@langchain/openai": "npm:@langchain/openai@^1.4.5",
    "@langchain/ollama": "npm:@langchain/ollama@^1.2.7",
    "@langchain/textsplitters": "npm:@langchain/textsplitters@^1.0.1",
    "@langchain/classic": "npm:@langchain/classic@^1.0.32",
    "@langchain/classic/": "npm:/@langchain/classic@^1.0.32/",
    "pdfjs-dist": "npm:pdfjs-dist@^5.7.284",
    "pdfjs-dist/": "npm:/pdfjs-dist@^5.7.284/",
    "pngjs": "npm:pngjs@^7.0.0",
    "mermaid": "npm:mermaid@^11.6.0",
    "@mozilla/readability": "npm:@mozilla/readability@^0.6.0",
    "linkedom": "npm:linkedom@^0.18.12",
    "puppeteer": "npm:puppeteer@^23",
    "puppeteer/": "npm:/puppeteer@^23/",
    "puppeteer-core": "npm:puppeteer-core@^23"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  },
  "allowScripts": ["npm:better-sqlite3@11.10.0"]
}
